@startuml IoT_Activity_Diagram
!theme plain

title Діаграма діяльності IoT клієнта - Повний цикл доставки

|#LightBlue|IoT Пристрій (Робот)|
start
:Ініціалізація системи;
note right
  - Підключення до WiFi
  - Ініціалізація GPIO (моторів, відсіку, кнопок)
  - Встановлення з'єднання з GPS модулем
  - Ініціалізація менеджера батареї
end note

:Автентифікація на сервері\n(POST /api/Auth/robot/login);

if (Автентифікація успішна?) then (Так)
  :Отримання JWT токену\n(роль "Iot");
else (Ні)
  :Логування помилки;
  stop
endif

:Перехід до стану IDLE;

|#LightGreen|Основний цикл|

repeat

  |IoT Пристрій (Робот)|
  :Очікування (10 секунд);

  :Перевірка наявності замовлень\n(GET /api/Robot/my-orders);

  |#LightCoral|Сервер|
  :Пошук замовлень,\nпризначених цьому роботу;

  if (Є призначені замовлення?) then (Так)

    |IoT Пристрій (Робот)|
    :Отримання деталей замовлення\n(маршрут, координати, вага);

    :Прийняття замовлення\n(POST /api/Robot/order/{id}/accept);

    |Сервер|
    :Оновлення статусу замовлення:\nPending → Processing;
    :Оновлення статусу робота:\nIdle → Delivering;

    |IoT Пристрій (Робот)|
    :Перехід до стану\nORDER_ASSIGNED;

    ' === ПОЛІТ ДО PICKUP ===
    partition "Політ до точки завантаження" {
      :Увімкнення моторів\n(GPIO25 = HIGH);

      :Розрахунок маршруту\nдо точки pickup;

      :Оновлення фази:\nFLIGHT_TO_PICKUP;

      :Надсилання телеметрії\nкожні 5 секунд;
      note right
        POST /api/Robot/status
        - BatteryLevel
        - CurrentLatitude
        - CurrentLongitude
        - Status: "Delivering"
      end note

      repeat
        :Навігація до точки pickup;
        :Перевірка рівня батареї;

        if (Батарея < 20%?) then (Так)
          :Аварійна зупинка;
          :Скасування замовлення;
          :Навігація до зарядки;
          stop
        endif

      repeat while (Досягнуто точки pickup?) is (Ні)
      -> Так;

      :Зупинка моторів\n(GPIO25 = LOW);

      :Оновлення фази:\nAT_PICKUP;
    }

    ' === ЗАВАНТАЖЕННЯ ===
    partition "Завантаження посилки" {
      :Відкриття вантажного відсіку\n(GPIO26 = PWM 90°);

      :Оновлення фази:\nOPEN_COMPARTMENT_PICKUP;

      :Очікування завантаження\n(5 секунд);

      :Оновлення фази:\nLOADING;

      :Закриття вантажного відсіку\n(GPIO26 = PWM 0°);

      :Оновлення фази:\nCLOSE_COMPARTMENT_PICKUP;
    }

    ' === ПОЛІТ ДО DROPOFF ===
    partition "Політ до точки доставки" {
      :Увімкнення моторів\n(GPIO25 = HIGH);

      :Розрахунок маршруту\nдо точки dropoff;

      :Оновлення фази:\nFLIGHT_TO_DROPOFF;

      |Сервер|
      :Оновлення статусу замовлення:\nProcessing → EnRoute;

      |IoT Пристрій (Робот)|
      repeat
        :Навігація до точки dropoff;
        :Надсилання телеметрії;
        :Перевірка рівня батареї;

        if (Батарея < 20%?) then (Так)
          :Аварійна зупинка;
          :Скасування замовлення;
          :Навігація до зарядки;
          stop
        endif

      repeat while (Досягнуто точки dropoff?) is (Ні)
      -> Так;

      :Зупинка моторів\n(GPIO25 = LOW);

      :Оновлення фази:\nAT_DROPOFF;
    }

    ' === РОЗВАНТАЖЕННЯ ===
    partition "Розвантаження посилки" {
      :Відкриття вантажного відсіку\n(GPIO26 = PWM 90°);

      :Оновлення фази:\nOPEN_COMPARTMENT_DROPOFF;

      |#Yellow|Користувач (Отримувач)|
      :Отримання повідомлення:\n"Посилка прибула!";

      |IoT Пристрій (Робот)|
      :Очікування натискання кнопки\nпідтвердження (GPIO27);
      note right
        Timeout: 60 секунд
        Якщо таймаут - автоматичне підтвердження
      end note

      if (Кнопка натиснута\nабо таймаут?) then (Так)
        :Оновлення фази:\nPACKAGE_DELIVERED;

        |Сервер|
        :Оновлення статусу замовлення:\nEnRoute → Delivered;
        :Оновлення статусу робота:\nDelivering → Idle;

        |IoT Пристрій (Робот)|
        :Закриття вантажного відсіку\n(GPIO26 = PWM 0°);
      endif
    }

    ' === ПЕРЕВІРКА БАТАРЕЇ ===
    partition "Перевірка потреби в зарядці" {
      if (Батарея < 50%?) then (Так)

        partition "Навігація до зарядки" {
          :Оновлення фази:\nFLIGHT_TO_CHARGING;

          |Сервер|
          :Оновлення статусу робота:\nIdle → Charging;

          |IoT Пристрій (Робот)|
          :Увімкнення моторів\n(GPIO25 = HIGH);

          :Пошук найближчої\nзарядної станції;

          repeat
            :Навігація до зарядної станції;
            :Надсилання телеметрії;
          repeat while (Досягнуто станції?) is (Ні)
          -> Так;

          :Зупинка моторів\n(GPIO25 = LOW);

          :Оновлення фази:\nAT_CHARGING_STATION;
        }

        partition "Процес зарядки" {
          :Перехід до стану CHARGING;

          :Активація індикатора зарядки\n(GPIO33 = HIGH);

          repeat
            :Моніторинг рівня батареї;
            :Надсилання телеметрії\n(статус: Charging);
            :Очікування 30 секунд;
          repeat while (Батарея >= 95%?) is (Ні)
          -> Так;

          :Деактивація індикатора\n(GPIO33 = LOW);

          |Sервер|
          :Оновлення статусу робота:\nCharging → Idle;

          |IoT Пристрій (Робот)|
          :Перехід до стану IDLE;
        }

      else (Ні)
        :Перехід до стану IDLE;
      endif
    }

  else (Ні)
    :Залишатись у стані IDLE;
  endif

repeat while (Система активна?) is (Так)
-> Ні;

:Завершення роботи системи;
:Вимкнення всіх GPIO;
stop

@enduml
